{
    "name": "jsdoc-scribe",
    "version": "2.4.1",
    "description": "Automated, AST-based JSDoc comment generator and static documentation site builder for JavaScript & TypeScript. Fast, deterministic, and 100% local (No AI involved).",
    "main": "lib/index.js",
    "types": "./lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./docs": {
            "types": "./lib/docs.d.ts",
            "default": "./lib/docs.js"
        },
        "./lint": {
            "types": "./lib/lint.d.ts",
            "default": "./lib/lint.js"
        }
    },
    "bin": {
        "gen-comments": "./bin/cli.js",
        "gen-docs": "./bin/gen-docs.js"
    },
    "files": [
        "bin",
        "lib",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "scripts": {
        "demo": "node bin/cli.js sample",
        "lint": "node bin/cli.js sample --lint --fix",
        "docs": "node bin/gen-docs.js sample --out docs --title jsdoc-scribe --quality",
        "docs:internal": "node bin/gen-docs.js lib bin packages/eslint-plugin-jsdoc-scribe --quality --out docs-internal --title jsdoc-scribe",
        "quality": "node bin/gen-docs.js lib bin packages/eslint-plugin-jsdoc-scribe --quality --quality-reporter console",
        "dashboard": "node bin/gen-docs.js lib bin packages/eslint-plugin-jsdoc-scribe --quality --data --out docs-dashboard --title jsdoc-scribe",
        "test": "node test/run.js",
        "prepublishOnly": "npm test"
    },
    "keywords": [
        "jsdoc",
        "comments",
        "documentation",
        "typescript",
        "javascript",
        "cli",
        "ast",
        "code-documentation",
        "comment-generator",
        "autodoc",
        "docs-generator",
        "jsdoc-generator",
        "static-site-generator",
        "ts",
        "js",
        "documentation-tool",
        "api-reference",
        "static-docs",
        "jsdoc-lint",
        "lint",
        "eslint-plugin-jsdoc",
        "autofix",
        "code-quality",
        "complexity",
        "dashboard"
    ],
    "author": {
        "name": "Chintan Goswami"
    },
    "license": "MIT",
    "engines": {
        "node": ">=14"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/imchintoo/jsdoc-scribe.git"
    },
    "homepage": "https://github.com/imchintoo/jsdoc-scribe#readme",
    "bugs": {
        "url": "https://github.com/imchintoo/jsdoc-scribe/issues"
    },
    "dependencies": {
        "typescript": ">=5.0.0"
    },
    "peerDependencies": {
        "code-multivitals": ">=1.6.0"
    },
    "peerDependenciesMeta": {
        "code-multivitals": {
            "optional": true
        }
    },
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "code-multivitals": "^1.6.1"
    }
}
